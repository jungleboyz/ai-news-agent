# ===========================================
# AI News Agent - Environment Configuration
# ===========================================
# Copy this file to .env and fill in your values

# ===========================================
# Required API Keys
# ===========================================

# OpenAI API key for embeddings
OPENAI_API_KEY=sk-your-openai-api-key

# Anthropic API key for Claude (summaries, clustering labels)
ANTHROPIC_API_KEY=sk-ant-your-anthropic-api-key

# ===========================================
# Database Configuration
# ===========================================

# PostgreSQL connection URL (for production)
# Leave unset to use SQLite for local development
# DATABASE_URL=postgresql://user:password@host:5432/dbname

# ===========================================
# Redis Configuration (Optional)
# ===========================================

# Redis URL for Celery background jobs
# REDIS_URL=redis://localhost:6379/0

# ===========================================
# Email Configuration (Optional)
# ===========================================

# Resend API key for email delivery (https://resend.com)
# RESEND_API_KEY=re_your_api_key

# Sender address (must be verified in Resend, or use onboarding@resend.dev for testing)
# EMAIL_FROM=digest@yourdomain.com

# Default recipient for digest/status emails
# EMAIL_TO=you@example.com

# ===========================================
# Application Settings
# ===========================================

# Environment (development, staging, production)
ENVIRONMENT=development

# Secret key for session encryption
# Generate with: python -c "import secrets; print(secrets.token_hex(32))"
SECRET_KEY=change-this-in-production

# Allowed hosts (comma-separated for production)
# ALLOWED_HOSTS=ripin.ai,www.ripin.ai

# ===========================================
# Feature Flags
# ===========================================

# Enable semantic scoring with embeddings
USE_SEMANTIC_SCORING=true

# Enable topic clustering
USE_TOPIC_CLUSTERING=true

# Enable personalization
USE_PERSONALIZATION=true

# ===========================================
# Scheduler Settings
# ===========================================

# Enable/disable the daily digest scheduler
SCHEDULER_ENABLED=true

# UTC hour and minute for the daily digest run (default: 19:00 UTC = 6 AM AEDT)
SCHEDULER_HOUR=19
SCHEDULER_MINUTE=0

# Secret for authenticating cron endpoint requests
# CRON_SECRET=change-this-in-production
